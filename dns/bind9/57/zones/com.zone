$TTL 86400
com. IN SOA ns1.com. admin.com. (
    2026032401  ; serial
    3600        ; refresh
    900         ; retry
    604800      ; expire
    86400       ; minimum
)

com. IN NS ns1.com.
ns1.com. IN A 172.20.0.57

; 把 example.com 指向权威DNS
example.com. IN NS ns1.example.com.
ns1.example.com. IN A 172.20.0.59
